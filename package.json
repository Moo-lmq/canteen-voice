{
  "name": "canteen-voice",
  "version": "1.0.0",
  "description": "校园食堂菜品评分与意见管理系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
